<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_gradient_gastro">

        <!-- Back arrow -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Departments"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="12dp" />

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_white_alpha"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:src="@drawable/heart"
                app:tint="@android:color/white" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gastrologist"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Digestive health specialists"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-light" />
    </LinearLayout>

    <!-- Scrollable Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stats Row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATS"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F77F00"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Doctors" android:textSize="10sp" android:textColor="#AAAAAA"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#D62828"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Rating"
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F77F00"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available"
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Doctors Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOCTORS"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Doctor Card 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="AK"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_orange"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Aisha Kamau"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GI Specialist · 10yr exp"
                        android:textSize="11sp"
                        android:textColor="#888888"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★ 4.9"
                        android:textSize="11sp"
                        android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="10sp"
                    android:textColor="#1A8C4E"
                    android:textStyle="bold"
                    android:background="@drawable/badge_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Doctor Card 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="MO"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_red"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dr. Mark Ochieng" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hepatologist · 7yr exp" android:textSize="11sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★★★★☆ 4.6" android:textSize="11sp" android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomorrow"
                    android:textSize="10sp"
                    android:textColor="#B07D0A"
                    android:textStyle="bold"
                    android:background="@drawable/badge_yellow"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Doctor Card 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="SN"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_orange_dark"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dr. Sarah Nakato" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Endoscopist · 5yr exp" android:textSize="11sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★★★★☆ 4.5" android:textSize="11sp" android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="10sp"
                    android:textColor="#1A8C4E"
                    android:textStyle="bold"
                    android:background="@drawable/badge_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Health Tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/card_white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health Tip"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#F77F00"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eat fiber-rich foods and stay hydrated to support digestive health."
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Book Button -->
    <Button
        android:id="@+id/btnBook"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        android:text="Book Appointment"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="#F77F00"
        app:cornerRadius="16dp"
        app:rippleColor="#33FFFFFF"/>

</LinearLayout>