<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    android:orientation="vertical">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#2D3436" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Notifications"
            android:textColor="#2D3436"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnMarkAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Mark all read"
            android:textColor="#2A5EE8"
            android:textSize="12sp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section: Today -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Today"
                android:textColor="#636E72"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Notification Card - Appointment Reminder (Unread) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <View
                        android:id="@+id/unread1"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginTop="4dp"
                        android:background="#2A5EE8"
                        android:backgroundTint="#2A5EE8" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/notif1Icon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E8F0FE">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/time"
                            app:tint="#2A5EE8" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/notif1Icon"
                        android:layout_toStartOf="@id/unread1"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Appointment Reminder"
                            android:textColor="#2D3436"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Your appointment with Dr. Sarah Johnson is tomorrow at 10:00 AM"
                            android:textColor="#636E72"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="2 hours ago"
                            android:textColor="#BDC3C7"
                            android:textSize="11sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notification Card - Medicine Reminder (Unread) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <View
                        android:id="@+id/unread2"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginTop="4dp"
                        android:background="#2A5EE8"
                        android:backgroundTint="#2A5EE8" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/notif2Icon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E8F5E9">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/medicine"
                            app:tint="#4CAF50" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/notif2Icon"
                        android:layout_toStartOf="@id/unread2"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medicine Reminder"
                            android:textColor="#2D3436"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Time to take Amoxicillin 500mg — 1 capsule after meal"
                            android:textColor="#636E72"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="5 hours ago"
                            android:textColor="#BDC3C7"
                            android:textSize="11sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Yesterday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:text="Yesterday"
                android:textColor="#636E72"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Notification Card - Order Delivered -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FAFAFA">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/notif3Icon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFF8E1">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/check"
 />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/notif3Icon"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order Delivered"
                            android:textColor="#636E72"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Your medicine order #MED2041 has been delivered successfully."
                            android:textColor="#95A5A6"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Yesterday, 3:20 PM"
                            android:textColor="#BDC3C7"
                            android:textSize="11sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notification Card - Doctor Reply -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FAFAFA">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/notif4Icon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardCornerRadius="23dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EDE7F6">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/communication"
                            app:tint="#673AB7" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/notif4Icon"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Message from Doctor"
                            android:textColor="#636E72"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Dr. Chen replied to your query about your test results."
                            android:textColor="#95A5A6"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Yesterday, 11:05 AM"
                            android:textColor="#BDC3C7"
                            android:textSize="11sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>