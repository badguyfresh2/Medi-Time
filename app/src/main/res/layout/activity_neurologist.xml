<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_gradient_neuro">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Departments"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="12dp" />

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_white_alpha"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/brain"
                app:tint="@android:color/white" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neurologist"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brain &amp; nervous system care"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-light" />
    </LinearLayout>

    <!-- Scrollable Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stats Row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATS"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="9" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#6A0DAD" android:fontFamily="sans-serif-black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Doctors" android:textSize="10sp" android:textColor="#AAAAAA"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4.8" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#3A0CA3" android:fontFamily="sans-serif-black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Rating" android:textSize="10sp" android:textColor="#AAAAAA"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/card_white">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#6A0DAD" android:fontFamily="sans-serif-black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Available" android:textSize="10sp" android:textColor="#AAAAAA"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Doctors Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOCTORS"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Doctor Card 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="PN"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_purple"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <!-- FIXED: Replaced empty textColor="" with #333333 to prevent InvocationTargetException during inflation -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dr. Peter Nsubuga" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Neurologist · 15yr exp" android:textSize="11sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★★★★★ 4.9" android:textSize="11sp" android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="10sp"
                    android:textColor="#1A8C4E"
                    android:textStyle="bold"
                    android:background="@drawable/badge_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Doctor Card 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="EM"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_indigo"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <!-- FIXED: Replaced empty textColor="" with #333333 to prevent InvocationTargetException during inflation -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dr. Eve Mwangi" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Epileptologist · 9yr exp" android:textSize="11sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★★★★★ 4.8" android:textSize="11sp" android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomorrow"
                    android:textSize="10sp"
                    android:textColor="#B07D0A"
                    android:textStyle="bold"
                    android:background="@drawable/badge_yellow"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Doctor Card 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="JA"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/avatar_purple_mid"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <!-- FIXED: Replaced empty textColor="" with #333333 to prevent InvocationTargetException during inflation -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dr. James Atim" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Stroke Specialist · 11yr exp" android:textSize="11sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★★★★☆ 4.7" android:textSize="11sp" android:textColor="#F5A623"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="10sp"
                    android:textColor="#1A8C4E"
                    android:textStyle="bold"
                    android:background="@drawable/badge_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Health Tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/card_white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health Tip"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6A0DAD"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep 7–9 hours nightly and manage stress to protect brain health."
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Book Button -->
    <Button
        android:id="@+id/btnBook"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        android:text="Book Appointment"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="#6A0DAD"
        app:cornerRadius="16dp"
        app:rippleColor="#33FFFFFF"/>

</LinearLayout>